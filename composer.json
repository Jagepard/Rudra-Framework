{
    "name": "rudra/framework",
    "description": "Rudra framework",
    "type": "library",
    "keywords": [
        "rudra",
        "framework",
        "mvc-framework",
        "mvc-pattern",
        "mvc-architecture",
        "mvc"
    ],
    "license": "MPL-2.0",
    "authors": [
        {
            "name": "Korotkov Danila",
            "email": "jagepard@yandex.ru",
            "homepage": "https://jagepard.ru", 
            "role": "Developer"
        }
    ],
    "support": {
        "email": "jagepard@yandex.ru",
        "issues": "https://github.com/Jagepard/Rudra-Framework/issues",
        "source": "https://github.com/Jagepard/Rudra-Framework"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "require": {
        "php": "^8.3",
        "filp/whoops": "^2.9",
        "ext-fileinfo": "*",
        "ext-pdo": "*",
        "phpmailer/phpmailer": "v7.1.1",
        "symfony/var-dumper": "v8.1.1",
        "symfony/yaml": "v8.1.1",
        "php-debugbar/php-debugbar": "^2.1",
        "rudra/annotation": "self.version",
        "rudra/auth": "self.version",
        "rudra/cli": "self.version",
        "rudra/container": "self.version",
        "rudra/controller": "self.version",
        "rudra/event-dispatcher": "self.version",
        "rudra/exception": "self.version",
        "rudra/model": "self.version",
        "rudra/oauth-client": "self.version",
        "rudra/pagination": "self.version",
        "rudra/redirect": "self.version",
        "rudra/router": "self.version",
        "rudra/validation": "self.version",
        "rudra/view": "self.version"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true,
        "platform-check": false
    },
    "scripts": {
        "post-create-project-cmd": [
            "@php scripts/post-create-project.php",
            "@php rudra secret"
        ]
    }
}
